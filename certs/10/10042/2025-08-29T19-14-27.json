  "product": {
    "idProduct": 13444,
    "idProductOrigin": "380",
    "fullName": "Обувь детская (размеры 17-40: мальчиковая, девичья, школьная, дошкольная, малодетская, для ясельного возраста) с комбинированным верхом из натуральной кожи, искусственной кожи и текстильных материалов, с отделкой (или без) из искусственной кожи, текстильных и полимерных материалов, утепленная и неутепленная, на подкладке из натурального меха, искусственного меха с шерстяным ворсом (кроме обуви для ясельного возраста), натуральной кожи и текстильных материалов (с вложением химических волокон не более 20% для малодетской и ясельной обуви), на подошве из натуральной кожи, полимерных материалов (ПУ, ТЭП, резина), клеевого и клеепрошивного методов крепления: сапожки, полусапожки, ботинки, в том числе типа кроссовок, кед и мокасин, полуботинки, в том числе типа кроссовок, кед и мокасин, туфли, в том числе открытые, туфли летние, сандалеты, пантолеты, в том числе ремешковые и типа сабо (с закрытой пяточной частью для детей в возрасте до 3 лет и фиксированной пяточной частью для детей в возрасте от 3 до 7 лет),",
    "marking": null,
    "usageScope": null,
    "storageCondition": null,
    "usageCondition": null,
    "batchSize": null,
    "batchId": null,
    "identification": "с маркировками \"NY&LON\", \"HITCH-HIKER\", \"JAKIOO\", \"MONNALISA\", \"MONNALISA CHIC\", \"MONNALISA BEACH\", \"MONNALISA BEBE\", \"MONNALISA FUN\", \"MONNALISA COUTURE\" (Приложение № 2, бланк 0272246)    ",
    "identifications": [
      {
        "idIdentification": 19809,
        "annex": false,
        "name": null,
        "type": null,
        "tradeMark": null,
        "model": null,
        "article": null,
        "sort": null,
        "idOkpds": [],
