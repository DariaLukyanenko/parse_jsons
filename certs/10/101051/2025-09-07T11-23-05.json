  "product": {
    "idProduct": 104453,
    "idProductOrigin": "156",
    "fullName": "Средства индивидуальной защиты рук от химических факторов (от растворов кислот концентрации до 50%;",
    "marking": null,
    "usageScope": null,
    "storageCondition": null,
    "usageCondition": null,
    "batchSize": null,
    "batchId": null,
    "identification": "от растворов щелочей концентрации до 30%; нефти и нефтепродуктов, масел, воды), от механических воздействий (от истирания; от проколов, порезов), на основе из хлопчатобумажного трикотажного полотна с полным, или частичным морозостойким (-30 0С) нитриловым покрытием, торговой марки «Petroleum», артикулов 7605, 7607, 7610, 7620, 7630, 7640: перчатки",
    "identifications": [
