  "product": {
    "idProduct": 13447,
    "idProductOrigin": "616",
    "fullName": "Обувь повседневная детская и подростковая (ясельная с закрытой  пяточной частью, малодетская и дошкольная с фиксированной пяточной  частью, для школьников-мальчиков, для школьников-девочек, мальчиковая, девичья) с верхом из хлопчатобумажной (100% хлопок) ткани, с подкладкой и вкладной стелькой из чистошерстяной ткани (100% шерсть), на подошве из полимерного материала (термопластичная резина): сапожки, полусапоги, ботинки",
    "marking": null,
    "usageScope": null,
